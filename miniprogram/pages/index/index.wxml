<view class="container">
  <!-- 主内容区域 -->
  <view class="main-content">
    <!-- 标题 -->
    <view class="page-title">
      <text class="title-text">管理后台</text>
    </view>

    <!-- 用户查询 -->
    <view class="query-section">
      <view class="section-header">
        <text class="section-title">用户查询</text>
      </view>
      <view class="query-form">
        <view class="input-wrapper">
          <input
            class="query-input"
            placeholder="请输入用户 openid"
            value="{{openidInput}}"
            bindinput="onOpenidInput"
          />
        </view>
        <button class="query-btn" bindtap="onUserQuery">
          查询用户
        </button>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-grid">
        <view class="menu-item" bindtap="onCustomerService">
          <view class="menu-icon">💬</view>
          <text class="menu-text">客服消息</text>
        </view>
        <view class="menu-item" bindtap="onInvoice">
          <view class="menu-icon">📄</view>
          <text class="menu-text">发票开具</text>
        </view>
      </view>
    </view>
  </view>
</view>
