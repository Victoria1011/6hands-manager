/* pages/invoice-list/invoice-list.wxss */
.container {
  min-height: 100vh;
  background-color: #F6F6F6;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 20rpx 24rpx;
  width: 100%;
}

.search-input {
  flex: 1;
  height: 64rpx;
  background-color: #F5F5F5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #1890FF;
}

/* 状态标签 */
.status-tabs {
  width: 100%;
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 10rpx 0;
  position: relative;
}

.tab-item.active {
  color: #1890FF;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1890FF;
  border-radius: 2rpx;
}

/* 发票列表 */
.invoice-list {
  width: 100%;
}

.invoice-card {
  background-color: #fff;
  border-radius: 12rpx;
  margin: 20rpx;
  overflow: hidden;
  border: 1rpx solid #E8E8E8;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s;
}

.invoice-card:active {
  transform: scale(0.99);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.invoice-type-tag {
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.invoice-type-tag.normal {
  background-color: #E6F7FF;
  color: #1890FF;
}

.invoice-type-tag.special {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.invoice-no {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.status-reviewing {
  background-color: #E6F7FF;
  color: #1890FF;
}

.status-invoicing {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.status-completed {
  background-color: #F6FFED;
  color: #52C41A;
}

.status-reviewing {
  background-color: #E6F7FF;
  color: #1890FF;
}

.status-reviewing.clickable {
  cursor: pointer;
  position: relative;
}

.status-reviewing.clickable::after {
  content: '→';
  position: absolute;
  right: -10rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: #1890FF;
  opacity: 0;
  transition: opacity 0.2s;
}

.status-reviewing.clickable:active::after {
  opacity: 1;
}

/* 上传开票信息区域 */
.upload-section {
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: flex-end;
}

.upload-btn {
  padding: 10rpx 24rpx;
  background-color: #1890FF;
  color: #fff;
  border-radius: 4rpx;
  font-size: 26rpx;
  cursor: pointer;
}

.card-body {
  padding: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  color: #999;
  min-width: 120rpx;
}

.value {
  flex: 1;
  color: #333;
  word-break: break-all;
}

.value.remark {
  line-height: 1.6;
  color: #666;
}

.value.invoice-link {
  color: #1890FF;
  word-break: break-all;
}

.value.copyable {
  cursor: pointer;
  position: relative;
  transition: all 0.2s;
}

.value.copyable:active {
  color: #1890FF;
  transform: scale(0.98);
}

.amount {
  color: #FF4D4F;
  font-weight: 500;
  font-size: 32rpx;
}

.order-nos {
  font-size: 26rpx;
}

/* 关联订单列表 */
.orders-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.orders-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.order-item {
  background-color: #FAFAFA;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-no {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.order-no.copyable {
  cursor: pointer;
  transition: all 0.2s;
}

.order-no.copyable:active {
  color: #1890FF;
  transform: scale(0.98);
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-content {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.order-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background-color: #F0F0F0;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.order-amount-tag {
  background-color: #FFF1F0;
  color: #FF4D4F;
  font-weight: 500;
}

.card-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.time {
  font-size: 24rpx;
  color: #999;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 640rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  cursor: pointer;
}

.modal-body {
  padding: 24rpx;
  max-height: 800rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input[disabled] {
  background-color: #F0F0F0;
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  cursor: pointer;
}

.cancel-btn {
  background-color: #F5F5F5;
  color: #666;
}

.confirm-btn {
  background-color: #1890FF;
  color: #fff;
}

/* 扫码按钮 */
.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 80rpx;
  background-color: #E6F7FF;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.2s;
}

.scan-btn:active {
  background-color: #BAE7FF;
  transform: scale(0.98);
}

.scan-icon {
  font-size: 32rpx;
}

.scan-text {
  font-size: 28rpx;
  color: #1890FF;
}

/* 发票详情弹窗 */
.invoice-detail-modal .modal-body {
  max-height: 1000rpx;
}

.input-section {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.invoice-detail-section {
  margin-top: 24rpx;
}

.detail-header {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.detail-warning {
  font-size: 24rpx;
  color: #FA8C16;
  background-color: #FFF7E6;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.detail-content {
  background-color: #FAFAFA;
  border-radius: 8rpx;
  padding: 20rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  color: #999;
  min-width: 140rpx;
  flex-shrink: 0;
  line-height: 1.5;
}

.detail-value {
  flex: 1;
  color: #333;
  word-break: break-all;
}

.detail-value.amount {
  color: #FF4D4F;
  font-weight: 500;
  font-size: 32rpx;
}

.detail-value.mismatch {
  color: #FF4D4F;
  font-weight: 500;
}

.warning-icon {
  color: #FF4D4F;
  margin-left: 8rpx;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20rpx 0;
}

.load-more-text {
  font-size: 28rpx;
  color: #1890FF;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
