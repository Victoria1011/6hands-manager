.container {
  min-height: 100vh;
  background: #F6F6F6;
  padding: 20rpx;
}

/* 头部 */
.header {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  width: 100%;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.header-buttons {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.batch-mode-btn {
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  background: white;
  border-radius: 8rpx;
  border: 2rpx solid #1890ff;
  color: #1890ff;
  transition: all 0.3s;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
  width: 160rpx !important;
  box-sizing: border-box;
}

.batch-mode-btn::after {
  border: none;
}

.batch-mode-active {
  background: #ff4d4f;
  border-color: #ff4d4f;
  color: #fff;
}

/* 批量操作工具栏 */
.batch-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff3cd;
  border-radius: 8rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  width: 100%;
}

.batch-select-all {
  padding: 8rpx 16rpx;
  background: #fff;
  border-radius: 6rpx;
  border: 2rpx solid #1890ff;
}

.select-all-text {
  font-size: 26rpx;
  color: #1890ff;
}

.batch-count {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
  margin-left: 20rpx;
}

.batch-delete-btn {
  padding: 8rpx 20rpx;
  font-size: 26rpx;
  background: #ff4d4f;
  color: #fff;
  border: none;
  border-radius: 6rpx;
}

.batch-delete-btn[disabled] {
  background: #ccc;
  color: #999;
}

.voice-type-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 4rpx;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
  box-shadow: 2rpx 2rpx 2rpx 2rpx rgba(0, 0, 0, 0.2);
}

.type-tab {
  padding: 12rpx 24rpx;
  font-size: 30rpx;
  color: #666;
  border-radius: 6rpx;
  transition: all 0.3s;
  width: 50% !important;
}

.type-tab-active {
  background: #fff;
  color: #1890ff;
  font-weight: 600;
  
}

.refresh-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
  width: 160rpx !important;
}

.refresh-btn::after {
  border: none;
}

/* 账号选项卡 */
.account-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 4rpx;
  gap: 4rpx;
  width: 100%;
  margin-top: 20rpx;
  box-shadow: 2rpx 2rpx 2rpx 2rpx rgba(0, 0, 0, 0.2);
}

.account-tab {
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 6rpx;
  transition: all 0.3s;
  flex: 1;
  text-align: center;
  white-space: nowrap;
}

.account-tab-active {
  background: #fff;
  color: #1890ff;
  font-weight: 600;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: space-around;
  align-items: center;
  width: 100%;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f0f0f0;
}

.stat-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #1890ff;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
}

/* 音色列表 */
.voice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.voice-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.voice-card-saved {
  background: linear-gradient(135deg, #f6ffed 0%, #f0f9ff 100%);
  border-left: 6rpx solid #52c41a;
}

.voice-card-batch {
  cursor: pointer;
  transition: all 0.3s;
}

.voice-card-batch:active {
  transform: scale(0.98);
  background: #fafafa;
}

.voice-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.voice-info {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.voice-checkbox {
  padding-top: 8rpx;
  flex-shrink: 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  background: #fff;
}

.checkbox-checked {
  background: #1890ff;
  border-color: #1890ff;
}

.check-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.voice-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
}

.voice-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  word-break: break-all;
  line-height: 1.5;
}

.voice-model {
  font-size: 24rpx;
  color: #666;
  background: #f0f0f0;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

.voice-actions {
  display: flex;
  gap: 12rpx;
  margin-left: 20rpx;
}

.copy-btn {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  background: #52c41a;
  color: #fff;
  border: none;
  border-radius: 6rpx;
}

.delete-btn {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  background: #ff4d4f;
  color: #fff;
  border: none;
  border-radius: 6rpx;
}

.voice-footer {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.voice-time {
  font-size: 24rpx;
  color: #999;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voice-account-badge {
  margin-top: 10rpx;
}

.account-badge-text {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  background: #1890ff;
  color: #fff;
  font-weight: 600;
}

.voice-users {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  position: relative;
}

.user-type-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  background: #52c41a;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.3);
}

.creator-badge {
  background: #1890ff;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.3);
}

.badge-text {
  font-size: 20rpx;
  font-weight: 600;
}

.user-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.user-info-row:last-child {
  margin-bottom: 0;
}

.user-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
  min-width: 140rpx;
}

.user-value {
  font-size: 22rpx;
  color: #1890ff;
  word-break: break-all;
  flex: 1;
}

.user-value-clickable {
  color: #1890ff;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.copy-icon {
  font-size: 24rpx;
  color: #52c41a;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
