.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.message-list {
  padding-top: 16rpx;
  width: 100%;
}

.message-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar-wrapper {
  margin-right: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #e8e8e8;
}

.content-wrapper {
  flex: 1;
  overflow: hidden;
}

.top-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.openid-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  margin-top: 20rpx;
}

.openid-label {
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.openid-value {
  flex: 1;
  font-size: 22rpx;
  color: #1f4467;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-left: 4rpx;
}
.last-message-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 40rpx;
}

.last-message {
  font-size: 28rpx;
  color: #222222;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  background-color: #675151;
  border-radius: 18rpx;
  font-size: 20rpx;
  color: #fff;
  text-align: center;
  line-height: 36rpx;
  flex-shrink: 0;
  vertical-align: middle;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading text {
  font-size: 28rpx;
  color: #999;
}
