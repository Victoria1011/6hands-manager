/**index.wxss**/
page {
  background-color: #f5f5f5;
  width: 100%;
}

.container {
  min-height: 100vh;
  width: 100%;
  padding: 40rpx 30rpx;
}

/* 登录弹窗样式 */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.login-modal {
  width: 80%;
  max-width: 600rpx;
}

.login-modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 48rpx;
}

.login-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  border: none;
  width: 100%;
}

.login-btn::after {
  border: none;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.header {
  padding: 60rpx 0 40rpx;
  width: 100%;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  margin-right: 24rpx;
}

.user-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.user-icon::after {
  content: '👤';
}

.service-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.service-icon::after {
  content: '💬';
}

.invoice-icon {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.invoice-icon::after {
  content: '📄';
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 300;
}
