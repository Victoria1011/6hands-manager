.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f8f9ff 0%, #eef2ff 50%, #f0f4ff 100%);
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 20% 30%, rgba(102, 126, 234, 0.03) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(118, 75, 162, 0.03) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 32rpx 24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  flex-shrink: 0;
  margin: 16rpx;
  margin-bottom: 0;
  border-radius: 20rpx;
  box-sizing: border-box;
  max-width: calc(100% - 32rpx);
  width: 100%;
}

.user-info {
  margin-bottom: 28rpx;
}

.user-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.user-label {
  color: rgba(255, 255, 255, 0.7);
  min-width: 140rpx;
  font-size: 24rpx;
}

.user-value {
  color: #fff;
  flex: 1;
  word-break: break-all;
  font-size: 24rpx;
  font-weight: 500;
}

.coins-value {
  color: #ffd700 !important;
  font-size: 28rpx !important;
  font-weight: bold !important;
}

.coins-icon {
  font-size: 32rpx;
  margin-left: 8rpx;
}

/* Tab 导航 */
.tab-nav {
  display: flex;
  gap: 0;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active {
  background: rgba(255, 255, 255, 0.25);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #fff;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: #fff;
  font-weight: bold;
}

/* Tab 内容区域 */
.tab-content {
  flex: 1;
  overflow: hidden;
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 0;
}

.tab-scroll {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.message-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  position: relative;
  z-index: 1;
  height: 100%;
  box-sizing: border-box;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
  padding: 0rpx 10rpx;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-item.self .avatar {
  margin-left: 20rpx;
  margin-right: 0;
}

.message-item.other .avatar {
  margin-right: 20rpx;
  margin-left: 0;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #e8e8e8;
  flex-shrink: 0;
}

.message-content {
  max-width: 60%;
  display: flex;
  flex-direction: column;
}

.message-item.self .message-content {
  align-items: flex-end;
}

.message-item.other .message-content {
  align-items: flex-start;
}

.time {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.text-message {
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.08);
}

.message-item.self .text-message {
  background: linear-gradient(135deg, #07c160 0%, #06b050 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.2);
}

.image-message {
  max-width: 400rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.12);
}

.card-message {
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 20rpx;
  min-width: 300rpx;
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.08);
}

.card-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.card-path {
  font-size: 24rpx;
  color: #999;
}

.sending {
  padding: 20rpx 24rpx;
  background-color: #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #999;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading text {
  font-size: 28rpx;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.input-wrapper {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx 40rpx 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.9) 100%);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(102, 126, 234, 0.08);
  width: 100%;
  position: relative;
  z-index: 10;
  box-shadow: 0 -4rpx 20rpx rgba(102, 126, 234, 0.05);
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  border-radius: 36rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(102, 126, 234, 0.05);
}

.send-btn {
  width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  background: linear-gradient(135deg, #e8e8e8 0%, #d8d8d8 100%);
  color: #999;
  border: none;
  font-size: 28rpx;
  border-radius: 32rpx;
  margin-left: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.send-btn.active {
  background: linear-gradient(135deg, #07c160 0%, #06b050 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
}

.icon-btn {
  width: 64rpx !important;
  height: 64rpx;
  padding: 10rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.1);
}

.icon-btn::after {
  border: none;
}

.plus-icon {
  font-size: 50rpx;
  font-weight: normal;
  color: #666;
  line-height: 1;
}

/* 快捷功能菜单 */
.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.action-sheet-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.action-sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.action-sheet-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.action-sheet-close {
  font-size: 48rpx;
  color: #999;
  padding: 8rpx 16rpx;
  line-height: 1;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  border-radius: 24rpx;
  font-size: 48rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.1);
  transition: all 0.3s ease;
}

.action-item:active .action-icon {
  transform: scale(0.95);
  box-shadow: 0 2rpx 6rpx rgba(102, 126, 234, 0.15);
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.send-btn[disabled] {
  opacity: 0.6;
}

/* 弹窗通用样式 */
.modal {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.6) 100%);
  backdrop-filter: blur(10rpx);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  max-height: 80vh;
  background: linear-gradient(135deg, #ffffff 0%, #fafbff 100%);
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  padding: 8rpx 16rpx;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #e8e8e8;
}

.modal-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  border: none;
  font-size: 28rpx;
  border-radius: 12rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.modal-btn::after {
  border: none;
}

.cancel-btn {
  background: linear-gradient(135deg, #f5f5f5 0%, #ebebeb 100%);
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.cancel-btn:active {
  background: linear-gradient(135deg, #ebebeb 0%, #e0e0e0 100%);
  transform: scale(0.98);
}

.confirm-btn {
  background: linear-gradient(135deg, #07c160 0%, #06b050 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.confirm-btn:active {
  background: linear-gradient(135deg, #06b050 0%, #05a040 100%);
  transform: scale(0.98);
}

/* 用户管理 */
.user-management {
  padding: 32rpx;
}

.user-management .setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.08);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.08);
}

.user-management .setting-label {
  font-size: 28rpx;
  color: #333;
}

.setting-reason {
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.08);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.08);
}

.reason-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.reason-input {
  height: 80rpx;
  padding: 16rpx;
  background: #fff;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
}

.blacklist-info {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.06) 0%, rgba(255, 77, 79, 0.02) 100%);
  border: 1rpx solid rgba(255, 77, 79, 0.1);
  border-radius: 12rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.info-value {
  flex: 1;
  font-size: 24rpx;
  color: #ff4d4f;
  word-break: break-all;
}

.save-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  background: linear-gradient(135deg, #5a6fd6 0%, #6a4190 100%);
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.4);
}

/* 用户管理弹窗（废弃） */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
}

/* 日志查询 */
.logs-container,
.orders-container {
  padding: 32rpx;
}

/* 日志查询弹窗（废弃） */
.logs-modal .modal-content {
  max-height: 70vh;
}

.logs-modal .modal-body {
  max-height: 500rpx;
}

.logs-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.log-item {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  overflow: hidden;
  transition: all 0.3s ease;
}

.log-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 28rpx rgba(102, 126, 234, 0.15);
}

/* 日志头部 */
.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.06) 0%, rgba(102, 126, 234, 0.02) 100%);
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.08);
}

.log-title {
  flex: 1;
}

.log-type {
  font-size: 26rpx;
  font-weight: 600;
  color: #667eea;
}

.log-time {
  font-size: 22rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 日志主体 */
.log-body {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.log-info-row {
  display: flex;
  align-items: center;
}

.log-label {
  font-size: 24rpx;
  color: #999;
  min-width: 120rpx;
}

.log-value {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
}

.log-id,
.log-audio-id {
  font-family: SFMono-Regular, Consolas, Monaco, monospace;
  font-size: 22rpx;
  color: #667eea;
  letter-spacing: 0.5rpx;
}

/* 日志底部 */
.log-footer {
  padding: 12rpx 24rpx 24rpx;
}

.log-cost {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.06) 0%, rgba(102, 126, 234, 0.02) 100%);
  border-radius: 12rpx;
}

.cost-label {
  font-size: 22rpx;
  color: #999;
  margin-right: 12rpx;
}

.cost-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffd700;
}

/* 订单信息 */
.orders-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 订单信息弹窗（废弃） */
.orders-modal .modal-content {
  max-height: 70vh;
}

.orders-modal .modal-body {
  max-height: 500rpx;
}

.order-item {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  overflow: hidden;
  transition: all 0.3s ease;
}

.order-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 28rpx rgba(102, 126, 234, 0.15);
}

/* 订单顶部 */
.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.06) 0%, rgba(102, 126, 234, 0.02) 100%);
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.08);
}

.order-no-text {
  font-size: 22rpx;
  color: #667eea;
  font-family: SFMono-Regular, Consolas, Monaco, monospace;
  flex: 1;
  letter-spacing: 0.5rpx;
}

.order-time {
  font-size: 22rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.06);
}

.order-title {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.4;
}

.order-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
}

.order-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
  margin-left: 16rpx;
}

.order-badge.status-pending {
  background: rgba(255, 165, 0, 0.12);
  color: #ffa500;
}

.order-badge.status-paid,
.order-badge.status-completed {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
}

.order-badge.status-cancelled,
.order-badge.status-failed {
  background: rgba(255, 77, 79, 0.12);
  color: #ff4d4f;
}

.order-badge.status-refunded {
  background: rgba(153, 153, 153, 0.12);
  color: #999;
}

.order-badge.status-refund_failed {
  background: rgba(255, 77, 79, 0.12);
  color: #ff4d4f;
}

/* 订单主体 */
.order-body {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  min-width: 120rpx;
}

.info-value {
  flex: 1;
  font-size: 24rpx;
  color: #333;
}

.order-no {
  font-family: SFMono-Regular, Consolas, Monaco, monospace;
  font-size: 22rpx;
  color: #667eea;
  letter-spacing: 0.5rpx;
}

/* 订单底部 */
.order-footer {
  display: flex;
  padding: 12rpx 24rpx 24rpx;
  gap: 32rpx;
}

.footer-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.06) 0%, rgba(102, 126, 234, 0.02) 100%);
  border-radius: 12rpx;
}

.footer-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.footer-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.footer-value.coins {
  color: #ffd700;
  font-size: 30rpx;
}

/* 订单额外信息 */
.order-extra {
  padding: 12rpx 24rpx 20rpx;
  background: rgba(102, 126, 234, 0.03);
  border-top: 1rpx solid rgba(102, 126, 234, 0.06);
}

