/**index.wxss**/
page {
  background: linear-gradient(180deg, #f8f9ff 0%, #eef2ff 50%, #f0f4ff 100%);
  width: 100%;
}

.container {
  min-height: 100vh;
  width: 100%;
  position: relative;
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.6) 100%);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.login-content {
  width: 80%;
  max-width: 600rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.login-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #667eea;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.input-group {
  display: flex;
  flex-direction: column;
}

.input-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.login-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: #fff;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: inset 0 2rpx 8rpx rgba(102, 126, 234, 0.05);
}

.login-input:focus {
  border-color: #667eea;
  box-shadow: inset 0 2rpx 8rpx rgba(102, 126, 234, 0.1), 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
  margin-top: 16rpx;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 主内容区域 */
.main-content {
  padding: 40rpx 32rpx;
  padding-bottom: 100rpx;
  width: 100%;
  box-sizing: border-box;
}

.page-title {
  text-align: center;
  margin-bottom: 48rpx;
}

.title-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #667eea;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* 查询区域 */
.query-section {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  margin-bottom: 32rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.query-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.input-wrapper {
  position: relative;
}

.query-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #fff;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: inset 0 2rpx 8rpx rgba(102, 126, 234, 0.05);
  font-family: SFMono-Regular, Consolas, Monaco, monospace;
  box-sizing: border-box;
}

.query-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.query-btn::after {
  border: none;
}

.query-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 功能菜单 */
.menu-section {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.06) 0%, rgba(102, 126, 234, 0.02) 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.08);
}

.menu-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.15);
}

.menu-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.menu-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}
