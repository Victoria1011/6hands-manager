/* 容器 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #edf2f7 100%);
}

/* 页面头部 - 渐变背景 */
.page-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* Tab 导航 - 现代胶囊设计 */
.tab-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8f9fa 100%);
  border-bottom: none;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  margin: 0 8rpx;
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  min-width: 140rpx;
}

.tab-item.active {
  color: #667eea;
}

.tab-item.active .tab-text {
  font-weight: 600;
  transform: scale(1.05);
}

.tab-item.active::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: calc(100% + 16rpx);
  height: 64rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.12) 0%, rgba(118, 75, 162, 0.12) 100%);
  border-radius: 32rpx;
  z-index: -1;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
  box-shadow: 0 2rpx 6rpx rgba(102, 126, 234, 0.4);
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  letter-spacing: 0.5rpx;
}

.tab-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  padding: 4rpx 10rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 18rpx;
  min-width: 32rpx;
  text-align: center;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.5);
  border: 2rpx solid #fff;
}

/* 列表滚动 */
.list-scroll {
  flex: 1;
  min-height: 0;
  padding: 24rpx 20rpx;
}

/* 加载和空状态 */
.loading, .empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
  flex-direction: column;
  gap: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* 退款列表 */
.refund-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.refund-item {
  background: linear-gradient(145deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06),
              0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.refund-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.refund-item:active::before {
  opacity: 1;
}

/* 退款项头部 */
.refund-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx dashed #e8e8e8;
}

.refund-title {
  display: flex;
  align-items: center;
  flex: 1;
}

.openid-text {
  font-size: 28rpx;
  color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.refund-time {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
  margin-left: 10rpx;
  margin-top: 10rpx;
}

/* 退款项内容 */
.refund-body {
  margin-bottom: 24rpx;
}

.refund-info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.refund-info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  min-width: 160rpx;
  font-weight: 400;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  font-weight: 400;
  line-height: 1.6;
}

.info-value.amount {
  color: #ff6b6b;
  font-weight: bold;
  font-size: 36rpx;
  letter-spacing: 0.5rpx;
}

.info-value.coins {
  color: #667eea;
  font-weight: bold;
  font-size: 36rpx;
  letter-spacing: 0.5rpx;
}

.info-value.order-no {
  font-family: 'Monaco', 'Consolas', monospace;
  color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.info-value.reason {
  color: #666;
  line-height: 1.6;
  background: #f8f9fa;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.info-value.reject-reason {
  color: #ff6b6b;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.08) 0%, rgba(255, 142, 142, 0.08) 100%);
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid #ff6b6b;
}

/* 订单详情卡片 */
.order-detail-card {
  margin: 20rpx 0;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.03) 0%, rgba(118, 75, 162, 0.03) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.order-detail-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed rgba(102, 126, 234, 0.15);
}

.detail-title-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.detail-title-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  letter-spacing: 0.5rpx;
}

.order-detail-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 订单头部行：商品名称和时间 */
.order-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

/* 商品名称：直接显示 */
.order-product-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  flex: 1;
}

/* 右上角时间 */
.order-time-right {
  font-size: 20rpx;
  color: #999;
  font-family: 'Monaco', 'Consolas', monospace;
  white-space: nowrap;
  margin-left: 16rpx;
}

/* 信息网格：横向紧凑排列 */
.order-info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 20rpx;
}

.order-info-item {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  min-width: 140rpx;
}

.info-key {
  font-size: 20rpx;
  color: #999;
  font-weight: 400;
}

.info-val {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

.info-val.amount {
  color: #ff6b6b;
  font-weight: 600;
}

.info-val.coins {
  color: #667eea;
  font-weight: 600;
}

.info-val.gift {
  color: #fa8c16;
  font-weight: 600;
}

.info-val.order-status-paid {
  color: #52c41a;
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1) 0%, rgba(138, 218, 76, 0.1) 100%);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

/* 订单间分割线 */
.order-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(102, 126, 234, 0.15) 20%, rgba(102, 126, 234, 0.15) 80%, transparent 100%);
  margin: 8rpx 0;
}

/* 退款操作按钮 - 现代设计 */
.refund-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.action-btn {
  width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  font-size: 28rpx;
  border-radius: 32rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.reject-btn {
  background: linear-gradient(145deg, #ffffff 0%, #f8f9fa 100%);
  color: #666;
  width: 200rpx !important;
  border: 2rpx solid #e8e8e8;
}

.reject-btn:active {
  background: #f5f5f5;
}

.approve-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  width: 200rpx !important;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.approve-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

/* 退款状态标签 - 现代设计 */
.refund-status {
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.status-rejected {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(255, 142, 142, 0.1) 100%);
  color: #ff6b6b;
  border: 1rpx solid rgba(255, 107, 107, 0.2);
}

.status-completed {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1) 0%, rgba(138, 218, 76, 0.1) 100%);
  color: #52c41a;
  border: 1rpx solid rgba(82, 196, 26, 0.2);
}

.status-approved {
  background: linear-gradient(135deg, rgba(250, 140, 22, 0.1) 0%, rgba(255, 165, 2, 0.1) 100%);
  color: #fa8c16;
  border: 1rpx solid rgba(250, 140, 22, 0.2);
}

.status-cancelled {
  background: linear-gradient(135deg, rgba(153, 153, 153, 0.1) 0%, rgba(170, 170, 170, 0.1) 100%);
  color: #999;
  border: 1rpx solid rgba(153, 153, 153, 0.2);
}

/* 弹窗样式 - 现代设计 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.dialog-content {
  width: 85%;
  background: linear-gradient(145deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15),
              0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(40rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #e8e8e8;
  background: linear-gradient(180deg, #ffffff 0%, #f8f9fa 100%);
}

.dialog-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 0.5rpx;
}

.dialog-close {
  font-size: 52rpx;
  color: #999;
  line-height: 1;
  font-weight: 300;
}

.dialog-body {
  padding: 32rpx;
}

.dialog-input {
  width: 100%;
  min-height: 240rpx;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  transition: all 0.3s ease;
  color: #333;
}

.dialog-input:focus {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.dialog-footer {
  display: flex;
  border-top: 1rpx solid #e8e8e8;
}

.dialog-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  font-size: 30rpx;
  border-radius: 0;
  border: none;
  font-weight: 500;
  transition: all 0.3s ease;
}

.cancel-btn {
  background: linear-gradient(180deg, #ffffff 0%, #f8f9fa 100%);
  color: #666;
  border-right: 1rpx solid #e8e8e8;
}

.cancel-btn:active {
  background: #f0f0f0;
}

.confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.confirm-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

/* 退款按钮样式 */
.refund-btn {
  background: linear-gradient(135deg, #fa8c16 0%, #ff7a45 100%);
  color: #fff;
  border: none;
  width: 300rpx !important;
  box-shadow: 0 4rpx 12rpx rgba(250, 140, 22, 0.3);
}

.refund-btn:active {
  box-shadow: 0 2rpx 8rpx rgba(250, 140, 22, 0.2);
}

/* 退款弹窗样式 */
.refund-dialog-content {
  max-height: 80vh;
  overflow-y: auto;
}

.refund-info-section {
  margin-bottom: 24rpx;
}

.refund-amount-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(250, 140, 22, 0.05) 0%, rgba(255, 122, 69, 0.05) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(250, 140, 22, 0.1);
}

.refund-amount-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  min-width: 120rpx;
}

.refund-amount-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  color: #fa8c16;
  font-weight: 600;
  background: #fff;
  border: 2rpx solid rgba(250, 140, 22, 0.2);
  border-radius: 8rpx;
  text-align: center;
}

.refund-amount-input:focus {
  border-color: #fa8c16;
  box-shadow: 0 0 0 4rpx rgba(250, 140, 22, 0.1);
}

.refund-amount-unit {
  font-size: 28rpx;
  color: #999;
  font-weight: 400;
}

/* 退款订单列表样式 */
.refund-orders-section {
  margin-top: 24rpx;
}

.refund-orders-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed rgba(250, 140, 22, 0.2);
}

.orders-title-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.orders-title-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fa8c16;
}

.refund-orders-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  max-height: 300rpx;
  overflow-y: auto;
}

.refund-order-item {
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.03) 0%, rgba(118, 75, 162, 0.03) 100%);
  border-radius: 8rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.08);
}

.refund-order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.refund-order-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.refund-order-amount {
  font-size: 26rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.refund-order-details {
  display: flex;
  gap: 16rpx;
}

.refund-order-detail {
  font-size: 20rpx;
  color: #999;
}

/* 退款总计信息 */
.refund-total-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(250, 140, 22, 0.15);
}

.refund-total-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.refund-total-value {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 600;
}

