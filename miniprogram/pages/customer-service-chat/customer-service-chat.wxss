.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.message-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-item.self .avatar {
  margin-left: 20rpx;
  margin-right: 0;
}

.message-item.other .avatar {
  margin-right: 20rpx;
  margin-left: 0;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #e8e8e8;
  flex-shrink: 0;
}

.message-content {
  max-width: 60%;
  display: flex;
  flex-direction: column;
}

.message-item.self .message-content {
  align-items: flex-end;
}

.message-item.other .message-content {
  align-items: flex-start;
}

.time {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.text-message {
  padding: 20rpx 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.message-item.self .text-message {
  background-color: #07c160;
  color: #fff;
}

.image-message {
  max-width: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.card-message {
  padding: 20rpx 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  min-width: 300rpx;
}

.card-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.card-path {
  font-size: 24rpx;
  color: #999;
}

.sending {
  padding: 20rpx 24rpx;
  background-color: #e8e8e8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #999;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading text {
  font-size: 28rpx;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.input-wrapper {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #e8e8e8;
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.send-btn {
  width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  background-color: #e8e8e8;
  color: #999;
  border: none;
  font-size: 28rpx;
  border-radius: 32rpx;
}

.send-btn.active {
  background-color: #07c160;
  color: #fff;
}

.send-btn[disabled] {
  opacity: 0.6;
}
