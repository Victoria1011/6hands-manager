.container {
  min-height: 100vh;
  background: #F6F6F6;
  padding: 20rpx;
}

/* 集合选择 */
.collection-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  width: 100%;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.picker-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  transition: all 0.3s;
}

.picker-container:active {
  background: #ebebeb;
  border-color: #1890ff;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.picker-placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 搜索 */
.search-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.search-field-wrapper,
.search-value-wrapper {
  flex: 1;
}

.search-input {
  width: 100%;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.search-btn {
  padding: 16rpx 30rpx;
  background: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 数据列表 */
.data-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.data-count {
  font-size: 26rpx;
  color: #999;
}

.data-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.data-item {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s;
}

.data-item:active {
  background: #f0f0f0;
  transform: scale(0.98);
}

.data-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.data-id {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
}

.data-action {
  font-size: 24rpx;
  color: #1890ff;
}

.data-item-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.data-field {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  font-size: 24rpx;
}

.field-key {
  color: #666;
  min-width: 140rpx;
  flex-shrink: 0;
}

.field-value {
  color: #333;
  flex: 1;
  word-break: break-all;
  font-family: monospace;
  font-size: 22rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #1890ff;
  font-size: 28rpx;
}

.load-more:active {
  opacity: 0.6;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  width: 100%;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-height: 80vh;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  cursor: pointer;
}

.modal-close:active {
  color: #666;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.edit-field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.field-textarea {
  width: 100%;
  min-height: 80rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  font-family: monospace;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
}

.btn-primary {
  background: #1890ff;
  color: #fff;
}

/* TTS Clone Logs 专用样式 */
.tts-item {
  background: #f9fbfd;
  border-color: #e3f2fd;
}

.logs-count {
  font-size: 24rpx;
  color: #1890ff;
  font-weight: 600;
}

.expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #e3f2fd;
  border-radius: 8rpx;
  margin-bottom: 0;
  transition: all 0.3s;
}

.expand-btn:active {
  background: #bbdefb;
}

.expand-btn text {
  font-size: 24rpx;
  color: #1890ff;
}

.logs-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 2rpx dashed #e3f2fd;
}

.log-item {
  background: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.log-voice {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.log-status {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-completed {
  background: #e8f5e9;
  color: #4caf50;
}

.status-failed {
  background: #ffebee;
  color: #f44336;
}

.status-processing {
  background: #e3f2fd;
  color: #2196f3;
}

.log-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.log-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.log-label {
  font-size: 24rpx;
  color: #999;
  min-width: 100rpx;
  flex-shrink: 0;
}

.log-value {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.text-value {
  color: #555;
  line-height: 1.6;
  max-height: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.cost-value {
  color: #f44336;
  font-weight: 600;
}

/* Upload File Logs 专用样式 */
.upload-item {
  background: #f9fff9;
  border-color: #e8f5e9;
}

.upload-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e8f5e9;
}

.upload-item-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.upload-field {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.upload-label {
  font-size: 26rpx;
  color: #666;
  min-width: 120rpx;
  flex-shrink: 0;
}

.upload-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.openid-value {
  color: #1890ff;
  font-family: monospace;
}

.file-id-value {
  color: #4caf50;
  font-family: monospace;
  font-weight: 500;
}

/* API Key Usage 专用样式 */
.apikey-item {
  background: #fefefe;
  border-color: #f0f0f0;
}

.apikey-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.apikey-item-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.apikey-section {
  background: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
  border: 2rpx solid #f0f0f0;
}

.apikey-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.apikey-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.apikey-stat {
  flex: 1;
  min-width: 200rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: #fff;
  border-radius: 6rpx;
  border: 2rpx solid #e8e8e8;
}

.apikey-stat-label {
  font-size: 26rpx;
  color: #666;
  min-width: 120rpx;
}

.apikey-stat-value {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 600;
}

.apikey-time {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
}

.apikey-time-label {
  font-size: 26rpx;
  color: #666;
  min-width: 120rpx;
}

.apikey-time-value {
  font-size: 26rpx;
  color: #333;
}

/* Coin Transactions 专用样式 */
.coin-item {
  background: #fff8f8;
  border-color: #ffecd9;
}

.coin-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #ffecd9;
}

.coin-openid-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.coin-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.coin-openid-value {
  font-size: 24rpx;
  color: #1890ff;
  font-family: monospace;
  word-break: break-all;
  flex: 1;
}

.coin-action {
  font-size: 24rpx;
  color: #1890ff;
  flex-shrink: 0;
}

.transactions-container {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 2rpx dashed #ffecd9;
}

.transaction-item {
  background: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  border: 2rpx solid #ffecd9;
}

.transaction-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.transaction-type {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.transaction-type.spend {
  background: #ffebee;
  color: #f44336;
}

.transaction-type.charge {
  background: #e8f5e9;
  color: #4caf50;
}

.transaction-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.transaction-amount.spend {
  color: #f44336;
}

.transaction-amount.charge {
  color: #4caf50;
}

.transaction-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.transaction-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.transaction-label {
  font-size: 24rpx;
  color: #999;
  min-width: 100rpx;
  flex-shrink: 0;
}

.transaction-value {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.coin-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  margin-top: 16rpx;
  background: #fff5f5;
  border-radius: 6rpx;
}

.coin-footer-label {
  font-size: 26rpx;
  color: #666;
}

.coin-footer-value {
  font-size: 26rpx;
  color: #333;
}
